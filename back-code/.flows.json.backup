  {
    "id": "http_status",
    "type": "http in",
    "z": "tab_api",
    "name": "状态接口",
    "url": "/api/v1/box/status",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 140,
    "y": 60,
    "wires": [
      [
        "fn_api_status"
      ]
    ]
  },
  {
    "id": "fn_api_status",
    "type": "function",
    "z": "tab_api",
    "name": "状态JSON",
    "func": "const d = global.get('latestTelemetry') || { deviceId: 'ESP32_BOX_001', temperature: 0, humidity: 0, capacity: 0, airQuality: 0, humanDetect: false, boxTiltAlert: false, fanStatus: false, frontLight: false, backLight: false, frontDoor: false, backDoor: false, tiltAngle: 0, sensorFaults: [], buzzerMode: 'off', netMode: 'STA', systemState: 'OFFLINE', lastSeen: 0, mqttOnline: false, mqttBrokerOnline: true, fullConfirmed: false, fullConfirming: false, fullConfirmMs: 0, fullReleaseMs: 0, frontManualHoldMs: 0, fanManualOverrideMs: 0, mpuCalibrated: false };\nconst age = d.lastSeen ? Date.now() - d.lastSeen : null;\nconst front = Boolean(d.frontLight ?? d.frontDoor ?? d.front_door ?? false);\nconst back = Boolean(d.backLight ?? d.backDoor ?? d.back_door ?? false);\nconst online = age !== null && age < 15000;\nmsg.statusCode = 200;\nmsg.payload = { code: 200, msg: 'ok', data: { ...d, frontLight: front, frontDoor: front, backLight: back, backDoor: back, online, lastTelemetryAgeMs: age, updatedAt: d.lastSeen ? new Date(d.lastSeen).toISOString() : null, mqttBrokerOnline: true, systemState: d.systemState || (online ? 'STANDBY' : 'OFFLINE') } };\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 370,
    "y": 60,
    "wires": [
      [
        "http_resp_status"
      ]
    ]
  },
  {
    "id": "http_resp_status",
    "type": "http response",
    "z": "tab_api",
    "name": "",
    "statusCode": "",
    "headers": {},
    "x": 600,
    "y": 60,
    "wires": []
  },
  {
    "id": "http_history",
    "type": "http in",
    "z": "tab_api",
    "name": "历史接口",
    "url": "/api/v1/box/history",
    "method": "get",
    "upload": false,
    "swaggerDoc": "",
    "x": 140,
    "y": 120,
    "wires": [
      [
        "fn_history_query"
      ]
    ]
  },
  {
    "id": "fn_history_query",
    "type": "function",
    "z": "tab_api",
    "name": "历史查询SQL",
    "func": "const q=msg.req&&msg.req.query?msg.req.query:{};const deviceId=q.deviceId||'ESP32_BOX_001';const limit=Math.max(1,Math.min(500,Number(q.limit||24)));msg.topic='SELECT * FROM telemetry WHERE device_id = $p1 ORDER BY ts DESC LIMIT $p2';msg.payload=[deviceId,limit];msg._queryType='history';return msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 370,
    "y": 120,
    "wires": [
      [
        "db_exec"
      ]
    ]
  },
  {
    "id": "fn_history_fmt",
    "type": "function",
    "z": "tab_api",
    "name": "历史返回",
    "func": "const rows=Array.isArray(msg.payload)?msg.payload:[];rows.reverse();msg.statusCode=200;msg.payload={code:200,msg:'ok',data:{timeline:rows.map(r=>new Date(r.ts).toLocaleTimeString('zh-CN',{hour12:false})),tempData:rows.map(r=>Number(r.temperature||0)),humidityData:rows.map(r=>Number(r.humidity||0)),airData:rows.map(r=>Number(r.air_quality||0)),capacityData:rows.map(r=>Number(r.capacity||0)),tiltData:rows.map(r=>Number(r.tilt_angle||0)),fanData:rows.map(r=>Number(r.fan_status||0)),frontData:rows.map(r=>Number(r.front_door||0)),backData:rows.map(r=>Number(r.back_door||0))}};return msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 590,
    "y": 120,
    "wires": [
      [
        "http_resp_history"
      ]
    ]
  },
  {
    "id": "http_resp_history",
    "type": "http response",
    "z": "tab_api",
    "name": "",
    "statusCode": "",
    "headers": {},
    "x": 800,
    "y": 120,
    "wires": []
  },
