    "id": "fn_alerts_read",
    "type": "function",
    "z": "tab_api",
    "name": "告警已读SQL",
    "func": "const body=msg.payload||{};const deviceId=body.deviceId||'ESP32_BOX_001';if(body.id){msg.topic='UPDATE alerts SET is_ack = 1 WHERE id = $p1';msg.payload=[body.id];}else{msg.topic='UPDATE alerts SET is_ack = 1 WHERE device_id = $p1';msg.payload=[deviceId];}msg.statusCode=200;msg.payload={code:200,msg:'ok',data:{updated:true,deviceId}};return [msg,null];",
    "outputs": 2,
    "noerr": 0,
