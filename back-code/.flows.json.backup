  {
    "id": "cb630220e2a2fd7c",
    "type": "ui_template",
    "z": "tab_core",
    "group": "ui_group_metrics",
    "name": "状态摘要",
    "order": 7,
    "width": 12,
    "height": 4,
    "format": "<style>\n  .panel-card {\n    position: relative;\n    padding: 16px 18px 14px;\n    border-radius: 16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,251,247,0.96));\n    border: 1px solid rgba(31,179,107,0.14);\n    box-shadow: 0 16px 34px rgba(24,52,78,0.10);\n    overflow: hidden;\n  }\n  .panel-card::before {\n    content: \"\";\n    position: absolute;\n    inset: 0 auto 0 0;\n    width: 5px;\n    background: linear-gradient(180deg, #1fb36b, #1592d0);\n  }\n  .panel-head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    margin-bottom: 10px;\n  }\n  .panel-title {\n    color: #177d52;\n    font-size: 18px;\n    font-weight: 900;\n    line-height: 1.2;\n  }\n  .panel-chip {\n    padding: 4px 10px;\n    border-radius: 999px;\n    background: rgba(31,179,107,0.10);\n    border: 1px solid rgba(31,179,107,0.16);\n    color: #177d52;\n    font-size: 12px;\n    font-weight: 800;\n    white-space: nowrap;\n  }\n  .panel-body {\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.75;\n    color: #32454a;\n    font-size: 14px;\n    font-weight: 700;\n    font-family: \"Microsoft YaHei\", Arial, sans-serif;\n  }\n</style>\n<div class=\"panel-card\">\n  <div class=\"panel-head\">\n    <div class=\"panel-title\">设备状态</div>\n    <div class=\"panel-chip\">Live</div>\n  </div>\n  <div class=\"panel-body\">{{msg.payload}}</div>\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "x": 580,
    "y": 440,
    "wires": [
      []
    ]
  },
  {
    "id": "966142f757d7bc76",
    "type": "ui_template",
    "z": "tab_core",
    "group": "ui_group_alerts",
    "name": "告警列表",
    "order": 1,
    "width": 12,
    "height": 5,
    "format": "<style>\n  .panel-card {\n    position: relative;\n    padding: 16px 18px 14px;\n    border-radius: 16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(251,249,241,0.96));\n    border: 1px solid rgba(242,200,76,0.18);\n    box-shadow: 0 16px 34px rgba(24,52,78,0.10);\n    overflow: hidden;\n  }\n  .panel-card::before {\n    content: \"\";\n    position: absolute;\n    inset: 0 auto 0 0;\n    width: 5px;\n    background: linear-gradient(180deg, #f2c84c, #1fb36b);\n  }\n  .panel-head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    margin-bottom: 10px;\n  }\n  .panel-title {\n    color: #b57a08;\n    font-size: 18px;\n    font-weight: 900;\n    line-height: 1.2;\n  }\n  .panel-chip {\n    padding: 4px 10px;\n    border-radius: 999px;\n    background: rgba(242,200,76,0.14);\n    border: 1px solid rgba(242,200,76,0.22);\n    color: #9f6700;\n    font-size: 12px;\n    font-weight: 800;\n    white-space: nowrap;\n  }\n  .panel-body {\n    white-space: pre-wrap;\n    word-break: break-word;\n    line-height: 1.75;\n    color: #32454a;\n    font-size: 14px;\n    font-weight: 700;\n    font-family: \"Microsoft YaHei\", Arial, sans-serif;\n  }\n</style>\n<div class=\"panel-card\">\n  <div class=\"panel-head\">\n    <div class=\"panel-title\">告警信息</div>\n    <div class=\"panel-chip\">Alert</div>\n  </div>\n  <div class=\"panel-body\">{{msg.payload}}</div>\n</div>",
