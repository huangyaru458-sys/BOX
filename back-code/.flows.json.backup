  {
    "id": "fn_telemetry",
    "type": "function",
    "z": "tab_core",
    "name": "遥测处理",
    "func": "const raw = msg.payload || {};\nconst prev = global.get('latestTelemetry') || {};\nconst now = Date.now();\n\nfunction toNumber(...vals) {\n  for (const v of vals) {\n    if (v === null || v === undefined || v === '') continue;\n    const n = Number(v);\n    if (Number.isFinite(n)) return n;\n  }\n  return undefined;\n}\n\nfunction toBool(...vals) {\n  for (const v of vals) {\n    if (v === null || v === undefined || v === '') continue;\n    if (typeof v === 'boolean') return v;\n    if (typeof v === 'number') return v !== 0;\n    const s = String(v).trim().toLowerCase();\n    if (['1', 'true', 'on', 'open', 'opened', 'yes', 'y'].includes(s)) return true;\n    if (['0', 'false', 'off', 'close', 'closed', 'no', 'n'].includes(s)) return false;\n  }\n  return undefined;\n}\n\nconst deviceId = String(raw.deviceId || raw.device_id || prev.deviceId || 'ESP32_BOX_001');\nconst front = toBool(raw.frontLight, raw.frontDoor, raw.front_door, prev.frontDoor, prev.frontLight);\nconst back = toBool(raw.backLight, raw.backDoor, raw.back_door, prev.backDoor, prev.backLight);\nconst temperature = toNumber(raw.temperature, raw.temp, prev.temperature);\nconst humidity = toNumber(raw.humidity, raw.hum, prev.humidity);\nconst capacity = toNumber(raw.capacity, raw.fullness, prev.capacity);\nconst airQuality = toNumber(raw.airQuality, raw.air_quality, raw.mq135, prev.airQuality);\nconst tiltAngle = toNumber(raw.tiltAngle, raw.tilt_angle, prev.tiltAngle);\nconst humanDetect = toBool(raw.humanDetect, raw.human_detect, raw.pir, prev.humanDetect);\nconst fanStatus = toBool(raw.fanStatus, raw.fan_status, prev.fanStatus);\nconst boxTiltAlert = toBool(raw.boxTiltAlert, raw.box_tilt_alert, prev.boxTiltAlert) || (Number.isFinite(tiltAngle) ? tiltAngle >= 25 : !!prev.boxTiltAlert);\nconst sensorFaults = Array.isArray(raw.sensorFaults) ? raw.sensorFaults : (Array.isArray(raw.sensor_faults) ? raw.sensor_faults : (Array.isArray(prev.sensorFaults) ? prev.sensorFaults : []));\nconst buzzerMode = raw.buzzerMode || raw.buzzer_mode || prev.buzzerMode || 'off';\nconst netMode = raw.netMode || raw.net_mode || prev.netMode || 'STA';\nconst wifiSsid = raw.wifiSsid || raw.wifi_ssid || prev.wifiSsid || '';\nconst mqttServer = raw.mqttServer || raw.mqtt_server || prev.mqttServer || '';\nconst mqttPort = toNumber(raw.mqttPort, raw.mqtt_port, prev.mqttPort, 1883) || 1883;\nconst staIp = raw.staIp || raw.sta_ip || prev.staIp || '';\nconst systemState = raw.systemState || prev.systemState || 'STANDBY';\nconst deviceTsRaw = toNumber(raw.timestamp, raw.ts, raw.deviceTs);\nconst deviceTimestampMs = Number.isFinite(deviceTsRaw) ? (deviceTsRaw < 1e12 ? deviceTsRaw * 1000 : deviceTsRaw) : null;\n\nconst data = {\n  deviceId,\n  temperature: Number.isFinite(temperature) ? temperature : Number(prev.temperature || 0),\n  humidity: Number.isFinite(humidity) ? humidity : Number(prev.humidity || 0),\n  capacity: Number.isFinite(capacity) ? capacity : Number(prev.capacity || 0),\n  airQuality: Number.isFinite(airQuality) ? airQuality : Number(prev.airQuality || 0),\n  humanDetect: !!(typeof humanDetect === 'boolean' ? humanDetect : prev.humanDetect),\n  boxTiltAlert: !!boxTiltAlert,\n  fanStatus: !!(typeof fanStatus === 'boolean' ? fanStatus : prev.fanStatus),\n  frontLight: typeof front === 'boolean' ? front : !!prev.frontLight,\n  backLight: typeof back === 'boolean' ? back : !!prev.backLight,\n  frontDoor: typeof front === 'boolean' ? front : !!prev.frontDoor,\n  backDoor: typeof back === 'boolean' ? back : !!prev.backDoor,\n  tiltAngle: Number.isFinite(tiltAngle) ? tiltAngle : Number(prev.tiltAngle || 0),\n  sensorFaults,\n  buzzerMode,\n  netMode,\n  wifiSsid,\n  mqttServer,\n  mqttPort,\n  staIp,\n  systemState,\n  deviceTimestampMs,\n  lastSeen: now,\n  mqttOnline: true\n};\n\nglobal.set('latestTelemetry', data);\nglobal.set('latestTelemetryRaw', raw);\n\nconst status = [\n  '设备: ' + data.deviceId,\n  '在线: 是',\n  '温度: ' + data.temperature.toFixed(1) + ' C',\n  '湿度: ' + data.humidity.toFixed(1) + ' %',\n  '满载率: ' + data.capacity.toFixed(1) + ' %',\n  '空气质量: ' + data.airQuality.toFixed(0),\n  '倾角: ' + data.tiltAngle.toFixed(1) + ' deg',\n  '倾斜告警: ' + (data.boxTiltAlert ? '是' : '否'),\n  '风扇: ' + (data.fanStatus ? '开' : '关'),\n  '前门: ' + (data.frontDoor ? '开' : '关'),\n  '后门: ' + (data.backDoor ? '开' : '关'),\n  '故障: ' + (data.sensorFaults.length ? data.sensorFaults.join(',') : '无')\n].join('\\n');\n\nreturn [\n  { payload: data.temperature, topic: 'temperature' },\n  { payload: data.humidity, topic: 'humidity' },\n  { payload: data.capacity, topic: 'capacity' },\n  { payload: data.airQuality, topic: 'airQuality' },\n  { payload: data.tiltAngle, topic: 'tiltAngle' },\n  { payload: status },\n  { topic: 'INSERT INTO telemetry (device_id,ts,temperature,humidity,capacity,air_quality,human_detect,fan_status,front_door,back_door,tilt_angle,sensor_faults,buzzer_mode,raw_json) VALUES ($p1,$p2,$p3,$p4,$p5,$p6,$p7,$p8,$p9,$p10,$p11,$p12,$p13,$p14)', payload: [data.deviceId, now, data.temperature, data.humidity, data.capacity, data.airQuality, data.humanDetect ? 1 : 0, data.fanStatus ? 1 : 0, data.frontDoor ? 1 : 0, data.backDoor ? 1 : 0, data.tiltAngle, JSON.stringify(data.sensorFaults), data.buzzerMode, JSON.stringify(raw)] },\n  { topic: 'INSERT INTO devices (device_id,device_name,online,last_seen,mqtt_online) VALUES ($p1,$p2,$p3,$p4,$p5) ON CONFLICT(device_id) DO UPDATE SET device_name=excluded.device_name,online=excluded.online,last_seen=excluded.last_seen,mqtt_online=excluded.mqtt_online', payload: [data.deviceId, 'ESP32_BOX_001', 1, now, 1] }\n];",
    "outputs": 9,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
