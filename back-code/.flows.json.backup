    ],
    "info": "<style>\r\n  :root {\r\n    --bg-a: #eef6ff;\r\n    --bg-b: #f7fbff;\r\n    --card: rgba(255, 255, 255, 0.86);\r\n    --ink: #172033;\r\n    --muted: #6c7a91;\r\n    --blue: #1f8fff;\r\n    --cyan: #00c2ff;\r\n    --green: #21c77a;\r\n    --orange: #ff9f1c;\r\n    --red: #ef4444;\r\n    --shadow: 0 18px 45px rgba(31, 79, 130, 0.16);\r\n  }\r\n\r\n  body,\r\n  md-content,\r\n  .nr-dashboard-theme md-content {\r\n    background:\r\n      radial-gradient(circle at 12% 8%, rgba(0, 194, 255, 0.18), transparent 28%),\r\n      radial-gradient(circle at 86% 14%, rgba(33, 199, 122, 0.16), transparent 26%),\r\n      linear-gradient(135deg, var(--bg-a), var(--bg-b)) !important;\r\n    color: var(--ink) !important;\r\n    font-family: \"Microsoft YaHei\", \"Segoe UI\", Arial, sans-serif !important;\r\n  }\r\n\r\n  md-toolbar,\r\n  .nr-dashboard-theme md-toolbar {\r\n    background: linear-gradient(135deg, #174b76, #2596d8) !important;\r\n    box-shadow: 0 10px 30px rgba(25, 96, 148, 0.28) !important;\r\n  }\r\n\r\n  md-toolbar .md-toolbar-tools {\r\n    font-weight: 900 !important;\r\n    letter-spacing: 0 !important;\r\n  }\r\n\r\n  .nr-dashboard-cardcontainer {\r\n    padding: 14px !important;\r\n  }\r\n\r\n  md-card,\r\n  .nr-dashboard-theme md-card {\r\n    position: relative !important;\r\n    border-radius: 18px !important;\r\n    background: var(--card) !important;\r\n    box-shadow: var(--shadow) !important;\r\n    border: 1px solid rgba(255, 255, 255, 0.78) !important;\r\n    backdrop-filter: blur(14px);\r\n    overflow: hidden !important;\r\n    transform: translateZ(0);\r\n  }\r\n\r\n  md-card::before {\r\n    content: \"\";\r\n    position: absolute;\r\n    inset: 0;\r\n    pointer-events: none;\r\n    background: linear-gradient(135deg, rgba(255,255,255,0.64), rgba(255,255,255,0.08));\r\n    opacity: 0.72;\r\n  }\r\n\r\n  md-card:hover {\r\n    transform: translateY(-3px) scale(1.008);\r\n    transition: 180ms ease;\r\n    box-shadow: 0 24px 58px rgba(31, 79, 130, 0.22) !important;\r\n  }\r\n\r\n  .nr-dashboard-widget,\r\n  .nr-dashboard-template {\r\n    color: var(--ink) !important;\r\n  }\r\n\r\n  .nr-dashboard-text,\r\n  .nr-dashboard-gauge,\r\n  .nr-dashboard-button,\r\n  .nr-dashboard-switch,\r\n  .nr-dashboard-chart {\r\n    position: relative;\r\n    z-index: 1;\r\n  }\r\n\r\n  .nr-dashboard-theme .nr-dashboard-text p,\r\n  .nr-dashboard-theme .nr-dashboard-text span,\r\n  .nr-dashboard-theme .nr-dashboard-text div {\r\n    color: var(--ink) !important;\r\n    font-weight: 800 !important;\r\n  }\r\n\r\n  .nr-dashboard-theme .nr-dashboard-button button {\r\n    border-radius: 14px !important;\r\n    min-height: 44px !important;\r\n    font-weight: 900 !important;\r\n    color: #fff !important;\r\n    background: linear-gradient(135deg, #1f8fff, #00c2ff) !important;\r\n    box-shadow: 0 10px 22px rgba(31, 143, 255, 0.25) !important;\r\n  }\r\n\r\n  .nr-dashboard-theme .nr-dashboard-button button:hover {\r\n    filter: brightness(1.04);\r\n    transform: translateY(-1px);\r\n  }\r\n\r\n  .nr-dashboard-theme md-tabs,\r\n  .nr-dashboard-theme md-tabs-wrapper {\r\n    background: transparent !important;\r\n  }\r\n\r\n  .nr-dashboard-theme md-tab-item {\r\n    color: #4d5b70 !important;\r\n    font-weight: 800 !important;\r\n  }\r\n\r\n  .nr-dashboard-theme md-tab-item.md-active {\r\n    color: #0f79c8 !important;\r\n  }\r\n\r\n  .nr-dashboard-theme md-ink-bar {\r\n    background: linear-gradient(90deg, var(--blue), var(--cyan)) !important;\r\n    height: 4px !important;\r\n    border-radius: 99px !important;\r\n  }\r\n\r\n  .iot-hero-wrap {\r\n    width: calc(100% - 28px);\r\n    margin: 16px 14px 4px;\r\n    border-radius: 22px;\r\n    min-height: 178px;\r\n    position: relative;\r\n    overflow: hidden;\r\n    background:\r\n      linear-gradient(135deg, rgba(16, 66, 107, 0.96), rgba(37, 150, 216, 0.92)),\r\n      radial-gradient(circle at 75% 30%, rgba(255,255,255,0.35), transparent 24%);\r\n    box-shadow: 0 26px 60px rgba(18, 92, 150, 0.28);\r\n    color: #fff;\r\n  }\r\n\r\n  .iot-hero {\r\n    display: grid;\r\n    grid-template-columns: 1fr 310px;\r\n    gap: 18px;\r\n    align-items: center;\r\n    padding: 26px 32px;\r\n  }\r\n\r\n  .iot-title {\r\n    font-size: 32px;\r\n    font-weight: 950;\r\n    line-height: 1.16;\r\n    margin-bottom: 10px;\r\n  }\r\n\r\n  .iot-sub {\r\n    color: rgba(255,255,255,0.82);\r\n    font-size: 15px;\r\n    font-weight: 700;\r\n  }\r\n\r\n  .iot-pills {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 10px;\r\n    margin-top: 18px;\r\n  }\r\n\r\n  .iot-pill {\r\n    padding: 8px 12px;\r\n    border-radius: 999px;\r\n    background: rgba(255,255,255,0.16);\r\n    border: 1px solid rgba(255,255,255,0.22);\r\n    font-size: 13px;\r\n    font-weight: 800;\r\n  }\r\n\r\n  .scene3d {\r\n    height: 160px;\r\n    perspective: 780px;\r\n    display: grid;\r\n    place-items: center;\r\n  }\r\n\r\n  .box3d {\r\n    position: relative;\r\n    width: 118px;\r\n    height: 118px;\r\n    transform-style: preserve-3d;\r\n    animation: boxSpin 7s infinite linear;\r\n  }\r\n\r\n  .face {\r\n    position: absolute;\r\n    width: 118px;\r\n    height: 118px;\r\n    border: 2px solid rgba(255,255,255,0.42);\r\n    background: linear-gradient(135deg, rgba(255,255,255,0.88), rgba(191,232,255,0.5));\r\n    box-shadow: inset 0 0 26px rgba(255,255,255,0.42);\r\n    border-radius: 10px;\r\n  }\r\n\r\n  .front { transform: translateZ(59px); }\r\n  .back { transform: rotateY(180deg) translateZ(59px); }\r\n  .right { transform: rotateY(90deg) translateZ(59px); }\r\n  .left { transform: rotateY(-90deg) translateZ(59px); }\r\n  .top { transform: rotateX(90deg) translateZ(59px); }\r\n  .bottom { transform: rotateX(-90deg) translateZ(59px); }\r\n\r\n  .box-light {\r\n    position: absolute;\r\n    width: 22px;\r\n    height: 22px;\r\n    border-radius: 50%;\r\n    left: 48px;\r\n    top: 48px;\r\n    background: #21c77a;\r\n    box-shadow: 0 0 24px #21c77a;\r\n    transform: translateZ(62px);\r\n  }\r\n\r\n  @keyframes boxSpin {\r\n    0% { transform: rotateX(-18deg) rotateY(0deg); }\r\n    100% { transform: rotateX(-18deg) rotateY(360deg); }\r\n  }\r\n\r\n  .iot-float {\r\n    position: absolute;\r\n    width: 82px;\r\n    height: 82px;\r\n    border-radius: 50%;\r\n    background: rgba(255,255,255,0.16);\r\n    right: 34px;\r\n    bottom: -28px;\r\n  }\r\n\r\n  @media (max-width: 760px) {\r\n    .iot-hero {\r\n      grid-template-columns: 1fr;\r\n      padding: 22px;\r\n    }\r\n\r\n    .scene3d {\r\n      height: 120px;\r\n    }\r\n\r\n    .iot-title {\r\n      font-size: 24px;\r\n    }\r\n  }\r\n</style>\r\n\r\n<script>\r\n(function () {\r\n  function injectHero() {\r\n    if (document.getElementById(\"iotHero3d\")) return;\r\n\r\n    var content = document.querySelector(\"md-content\") || document.body;\r\n    var hero = document.createElement(\"div\");\r\n    hero.id = \"iotHero3d\";\r\n    hero.className = \"iot-hero-wrap\";\r\n    hero.innerHTML = `\r\n      <div class=\"iot-hero\">\r\n        <div>\r\n          <div class=\"iot-title\">智能衣物回收箱管理系统</div>\r\n          <div class=\"iot-sub\">实时监测 · MQTT 控制 · 数据留存 · 设备状态同步</div>\r\n          <div class=\"iot-pills\">\r\n            <div class=\"iot-pill\">ESP32 在线监控</div>\r\n            <div class=\"iot-pill\">前门 GPIO33</div>\r\n            <div class=\"iot-pill\">后门 GPIO12</div>\r\n            <div class=\"iot-pill\">告警灯 GPIO14</div>\r\n          </div>\r\n        </div>\r\n        <div class=\"scene3d\">\r\n          <div class=\"box3d\">\r\n            <div class=\"face front\"></div>\r\n            <div class=\"face back\"></div>\r\n            <div class=\"face right\"></div>\r\n            <div class=\"face left\"></div>\r\n            <div class=\"face top\"></div>\r\n            <div class=\"face bottom\"></div>\r\n            <div class=\"box-light\"></div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"iot-float\"></div>\r\n    `;\r\n\r\n    var first = content.firstChild;\r\n    content.insertBefore(hero, first);\r\n  }\r\n\r\n  setTimeout(injectHero, 600);\r\n  setTimeout(injectHero, 1600);\r\n})();\r\n</script>"
  },
