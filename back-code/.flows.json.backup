  {
    "id": "ui_theme_3d_clothes_box",
    "type": "ui_template",
    "z": "tab_dash",
    "group": "ui_group_metrics",
    "name": "仪表盘整体美化CSS",
    "order": 0,
    "width": 18,
    "height": 4,
    "format": "\n<style>\n  :root{\n    --bg:#f4faf6;\n    --panel:rgba(255,255,255,.96);\n    --line:rgba(31,179,107,.14);\n    --text:#183128;\n    --muted:#6a7a72;\n    --green:#1fb36b;\n    --green2:#159d5b;\n    --blue:#1d9bf0;\n    --amber:#f2c84c;\n    --shadow:0 12px 28px rgba(24,52,78,.10);\n  }\n\n  html, body,\n  md-content,\n  .nr-dashboard-theme md-content {\n    background: var(--bg) !important;\n    color: var(--text) !important;\n    font-family: \"Microsoft YaHei\", Arial, sans-serif !important;\n  }\n\n  .nr-dashboard-theme md-toolbar {\n    min-height: 60px !important;\n    background: linear-gradient(90deg, #145f80, #1e965f) !important;\n    box-shadow: 0 8px 24px rgba(16,75,118,.18) !important;\n  }\n\n  .nr-dashboard-theme md-toolbar .md-toolbar-tools {\n    font-size: 20px !important;\n    font-weight: 900 !important;\n    letter-spacing: 0 !important;\n  }\n\n  .nr-dashboard-theme md-tabs-wrapper {\n    background: rgba(255,255,255,.92) !important;\n    border-bottom: 1px solid var(--line) !important;\n  }\n\n  .nr-dashboard-theme md-tab-item {\n    color: var(--muted) !important;\n    font-weight: 800 !important;\n  }\n\n  .nr-dashboard-theme md-tab-item.md-active {\n    color: #177d52 !important;\n  }\n\n  .nr-dashboard-theme md-ink-bar {\n    height: 3px !important;\n    background: linear-gradient(90deg, var(--green), var(--amber)) !important;\n  }\n\n  .nr-dashboard-cardcontainer {\n    max-width: 1460px !important;\n    margin: 0 auto !important;\n    padding: 14px !important;\n  }\n\n  md-card,\n  .nr-dashboard-theme md-card {\n    border-radius: 14px !important;\n    background: var(--panel) !important;\n    border: 1px solid rgba(255,255,255,.82) !important;\n    box-shadow: var(--shadow) !important;\n    overflow: hidden !important;\n  }\n\n  .nr-dashboard-button button {\n    border-radius: 12px !important;\n    min-height: 48px !important;\n    font-weight: 900 !important;\n    color: #fff !important;\n    border: none !important;\n  }\n\n  .nr-dashboard-button button:hover {\n    filter: brightness(1.04);\n  }\n</style>\n\n<div class=\"dash-hero\">\n  <div>\n    <div class=\"dash-title\">智能衣物回收箱</div>\n    <div class=\"dash-sub\">把温湿度、满载率、空气质量、倾倒角度、门禁和告警状态收在一个更清爽的视图里。</div>\n    <div class=\"dash-tags\">\n      <span class=\"dash-tag\">ESP32_BOX_001</span>\n      <span class=\"dash-tag\">MQTT / Node-RED</span>\n      <span class=\"dash-tag\">实时监测</span>\n      <span class=\"dash-tag\">告警联动</span>\n    </div>\n    <div class=\"dash-kpis\">\n      <div class=\"dash-kpi\"><strong>在线监控</strong><span>设备状态和传感器数据同步展示</span></div>\n      <div class=\"dash-kpi\"><strong>统一控制</strong><span>前门、后门、风扇与告警按钮集中管理</span></div>\n    </div>\n  </div>\n  <div class=\"dash-device\" aria-hidden=\"true\">\n    <span class=\"dot one\"></span>\n    <span class=\"dot two\"></span>\n    <span class=\"dot three\"></span>\n    <span class=\"door front\"></span>\n    <span class=\"door back\"></span>\n  </div>\n</div>",
    "storeOutMessages": false,
    "fwdInMessages": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 520,
    "y": 480,
    "wires": [
      []
    ]
  }
