	padding: 16rpx 20rpx;
	border-radius: 12rpx;
	font-size: 26rpx;
	&.tilt {
		background: #fff7e6;
		color: #fa8c16;
	}
	&.fault {
		background: #fff1f0;
		color: #ff4d4f;
	}
}

.alert-icon {
	font-size: 28rpx;
}

.system-list {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 16rpx;
}

.system-item {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 16rpx 20rpx;
