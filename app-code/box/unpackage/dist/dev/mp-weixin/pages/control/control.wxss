.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.section-header {
  margin-bottom: 20rpx;
}
.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.section-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.control-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.control-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}
.control-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.control-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}
.control-buttons {
  display: flex;
  gap: 12rpx;
}
.btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.btn:active {
  transform: scale(0.95);
}
.btn.btn-open {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}
.btn.btn-close {
  background: linear-gradient(135deg, #ff6b6b, #ff8e53);
}
.btn.btn-warning {
  background: linear-gradient(135deg, #faad14, #ffc53d);
}
.btn.btn-normal {
  background: #e8e8e8;
}
.btn.btn-normal .btn-text {
  color: #666;
}
.btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
}
.toggle-switch {
  width: 120rpx;
  height: 64rpx;
  background: #e8e8e8;
  border-radius: 32rpx;
  position: relative;
  margin: 0 auto;
  transition: background 0.3s ease;
}
.toggle-switch.active {
  background: linear-gradient(135deg, #1a73e8, #4285f4);
}
.toggle-thumb {
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
.toggle-switch.active .toggle-thumb {
  left: 60rpx;
}
.toggle-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}
.alert-controls {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.alert-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  border-left: 6rpx solid #fa8c16;
}
.alert-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}
.alert-info {
  flex: 1;
}
.alert-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #d46b08;
}
.alert-desc {
  display: block;
  font-size: 24rpx;
  color: #fa8c16;
  margin-top: 4rpx;
}
.alert-arrow {
  font-size: 36rpx;
  color: #fa8c16;
}
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.quick-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  transition: all 0.2s ease;
}
.quick-item:active {
  transform: scale(0.95);
  background: #e8f0fe;
}
.quick-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}
.quick-text {
  display: block;
  font-size: 22rpx;
  color: #666;
}
.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.history-list {
  max-height: 400rpx;
  overflow-y: auto;
}
.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.history-item:last-child {
  border-bottom: none;
}
.history-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ccc;
  margin-right: 16rpx;
}
.history-dot.success {
  background: #52c41a;
}
.history-dot.failed {
  background: #ff4d4f;
}
.history-action {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.history-time {
  font-size: 24rpx;
  color: #999;
}
.empty-history {
  text-align: center;
  padding: 40rpx;
}
.empty-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #999;
}