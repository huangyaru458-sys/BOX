.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
}
.filter-tabs {
  display: flex;
  gap: 40rpx;
}
.filter-tab {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}
.filter-tab.active {
  background: #1a73e8;
}
.filter-tab.active .tab-text {
  color: #fff;
}
.tab-text {
  font-size: 28rpx;
  color: #666;
}
.filter-tab.active .tab-text {
  font-weight: 500;
}
.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}
.filter-icon {
  font-size: 28rpx;
}
.filter-text {
  font-size: 26rpx;
  color: #666;
}
.content-area {
  padding: 20rpx;
}
.telemetry-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.list-header {
  display: flex;
  padding: 20rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #e8e8e8;
}
.header-item {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
  text-align: center;
}
.list-item {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child {
  border-bottom: none;
}
.item-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: center;
}
.item-text.active {
  color: #1a73e8;
  font-weight: 500;
}
.alerts-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.alert-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.alert-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.alert-icon-wrapper.tilt {
  background: #fff7e6;
}
.alert-icon-wrapper.fault {
  background: #fff1f0;
}
.alert-icon-wrapper.full {
  background: #e6f7ff;
}
.alert-icon-wrapper.other {
  background: #f6ffed;
}
.alert-icon {
  font-size: 32rpx;
}
.alert-content {
  flex: 1;
}
.alert-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}
.alert-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}
.alert-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #f0f0f0;
}
.alert-status.acked {
  background: #e6f7ff;
}
.alert-status.acked .status-text {
  color: #1890ff;
}
.status-text {
  font-size: 22rpx;
  color: #999;
}
.empty-state {
  text-align: center;
  padding: 60rpx;
}
.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}
.load-more {
  padding: 30rpx;
  text-align: center;
}
.load-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.load-text {
  font-size: 28rpx;
  color: #1a73e8;
}