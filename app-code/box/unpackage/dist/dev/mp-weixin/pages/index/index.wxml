<view id="{{A}}" change:eS="{{uV.sS}}" eS="{{$eS[A]}}" change:eA="{{uV.sA}}" eA="{{$eA[A]}}" class="{{['container', virtualHostClass]}}" style="{{virtualHostStyle}}" hidden="{{virtualHostHidden || false}}"><view class="status-bar"><view class="status-item"><view class="{{['status-dot', a && 'online', b && 'offline']}}"></view><text class="status-text">{{c}}</text></view><text class="update-time">更新于 {{d}}</text></view><view class="sensor-grid"><view class="sensor-card"><view class="sensor-icon temp-icon"><text class="icon-text">🌡</text></view><view class="sensor-info"><text class="sensor-value">{{e}}</text><text class="sensor-unit">°C</text></view><text class="sensor-label">温度</text></view><view class="sensor-card"><view class="sensor-icon humidity-icon"><text class="icon-text">💧</text></view><view class="sensor-info"><text class="sensor-value">{{f}}</text><text class="sensor-unit">%</text></view><text class="sensor-label">湿度</text></view><view class="sensor-card"><view class="sensor-icon capacity-icon"><text class="icon-text">📦</text></view><view class="sensor-info"><text class="sensor-value">{{g}}</text><text class="sensor-unit">%</text></view><text class="sensor-label">容量</text><view class="capacity-bar"><view style="{{'width:' + h}}" class="{{['capacity-fill', i && 'full']}}"></view></view></view><view class="sensor-card"><view class="sensor-icon air-icon"><text class="icon-text">🌬</text></view><view class="sensor-info"><text class="sensor-value">{{j}}</text><text class="sensor-unit">ppm</text></view><text class="sensor-label">空气质量</text></view></view><view class="device-section"><view class="section-title">设备状态</view><view class="device-grid"><view class="{{['device-item', l && 'active']}}"><view class="device-icon">🚪</view><text class="device-name">前门</text><text class="device-status">{{k}}</text></view><view class="{{['device-item', n && 'active']}}"><view class="device-icon">🔒</view><text class="device-name">后门</text><text class="device-status">{{m}}</text></view><view class="{{['device-item', p && 'active']}}"><view class="device-icon">🌀</view><text class="device-name">风扇</text><text class="device-status">{{o}}</text></view><view class="{{['device-item', r && 'active']}}"><view class="device-icon">👤</view><text class="device-name">人体感应</text><text class="device-status">{{q}}</text></view></view></view><view wx:if="{{s}}" class="alert-section"><view class="section-title">告警信息</view><view class="alert-list"><view wx:if="{{t}}" class="alert-item tilt"><text class="alert-icon">⚠️</text><text class="alert-text">设备倾斜告警</text></view><view wx:for="{{v}}" wx:for-item="fault" wx:key="b" class="alert-item fault"><text class="alert-icon">❌</text><text class="alert-text">{{fault.a}}</text></view></view></view><view class="system-section"><view class="section-title">系统信息</view><view class="system-list"><view class="system-item"><text class="system-label">系统状态</text><text class="system-value">{{w}}</text></view><view class="system-item"><text class="system-label">网络模式</text><text class="system-value">{{x}}</text></view><view class="system-item"><text class="system-label">蜂鸣器</text><text class="system-value">{{y}}</text></view><view class="system-item"><text class="system-label">倾斜角度</text><text class="system-value">{{z}}°</text></view></view></view></view><wxs src="/common/uniView.wxs" module="uV"/>
