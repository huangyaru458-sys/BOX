{
  "pages": [
    "pages/index/index",
    "pages/control/control",
    "pages/history/history"
  ],
  "window": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "智能回收箱",
    "navigationBarBackgroundColor": "#1a73e8",
    "backgroundColor": "#f5f5f5"
  },
  "tabBar": {
    "color": "#8a8a8a",
    "selectedColor": "#1a73e8",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "监控",
        "iconPath": "static/icons/home.png",
        "selectedIconPath": "static/icons/home-active.png"
      },
      {
        "pagePath": "pages/control/control",
        "text": "控制",
        "iconPath": "static/icons/control.png",
        "selectedIconPath": "static/icons/control-active.png"
      },
      {
        "pagePath": "pages/history/history",
        "text": "历史",
        "iconPath": "static/icons/history.png",
        "selectedIconPath": "static/icons/history-active.png"
      }
    ]
  },
  "themeLocation": "theme.json",
  "darkmode": true,
  "resizable": true,
  "frameset": true,
  "requiredPrivateInfos": [
    "getLocation",
    "onLocationChange",
    "startLocationUpdateBackground"
  ],
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于小程序位置接口的效果展示"
    }
  },
  "workers": "workers",
  "usingComponents": {}
}