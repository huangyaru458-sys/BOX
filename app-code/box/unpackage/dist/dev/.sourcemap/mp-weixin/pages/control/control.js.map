			</view>
			<view class="quick-actions">
				<view class="quick-item" @click="sendCommand('FAN_ON')">
					<view class="quick-icon">❄️</view>
					<text class="quick-text">开启通风</text>
				</view>
				<view class="quick-item" @click="sendCommand('FAN_OFF')">
