<script setup lang="uts">
import { ref } from 'vue';
import { api, CONTROL_COMMANDS } from '@/api/device';

const fanState = ref(false);
const history = ref<Array<{ action: string; time: string; success: boolean }>>([]);

const sendCommand = async (action: string) => {
	try {
		const result = await api.sendControl(action);
		const now = new Date();
		const timeStr = `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}:${now.getSeconds().toString().padStart(2, '0')}`;
		
		const actionMap: Record<string, string> = {
			[CONTROL_COMMANDS.FRONT_DOOR_OPEN]: '打开前门',
			[CONTROL_COMMANDS.FRONT_DOOR_CLOSE]: '关闭前门',
			[CONTROL_COMMANDS.BACK_DOOR_OPEN]: '打开后门',
			[CONTROL_COMMANDS.BACK_DOOR_CLOSE]: '关闭后门',
			[CONTROL_COMMANDS.FAN_ON]: '开启风扇',
			[CONTROL_COMMANDS.FAN_OFF]: '关闭风扇',
			[CONTROL_COMMANDS.BUZZER_ON]: '开启蜂鸣器',
			[CONTROL_COMMANDS.BUZZER_OFF]: '关闭蜂鸣器',
			[CONTROL_COMMANDS.ALARM_STOP]: '停止告警'
		};

		history.value.unshift({
			action: actionMap[action] || action,
			time: timeStr,
			success: result.code === 200
		});

		if (history.value.length > 20) {
			history.value = history.value.slice(0, 20);
		}

		if (action === CONTROL_COMMANDS.FAN_ON) {
			fanState.value = true;
		} else if (action === CONTROL_COMMANDS.FAN_OFF) {
			fanState.value = false;
		}

		if (result.data?.offlineWarning) {
			uni.showToast({
				title: '设备离线，指令已缓存',
				icon: 'none',
				duration: 2000
			});
		} else {
			uni.showToast({
				title: '指令发送成功',
				icon: 'success',
				duration: 1500
			});
		}
	} catch (e) {
		uni.showToast({
			title: '发送失败',
			icon: 'error',
			duration: 1500
		});
	}
};

const toggleFan = () => {
	if (fanState.value) {
		sendCommand(CONTROL_COMMANDS.FAN_OFF);
	} else {
		sendCommand(CONTROL_COMMANDS.FAN_ON);
	}
};
</script>

