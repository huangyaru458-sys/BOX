			</view>
			<view class="history-list">
				<view class="history-item" v-for="(record, index) in history" :key="index">
					<view class="history-dot" :class="record.success ? 'success' : 'failed'"></view>
					<text class="history-action">{{ record.action }}</text>
					<text class="history-time">{{ record.time }}</text>
				</view>
				<view class="empty-history" v-if="history.length === 0">
					<text class="empty-icon">📋</text>
					<text class="empty-text">暂无操作记录</text>
