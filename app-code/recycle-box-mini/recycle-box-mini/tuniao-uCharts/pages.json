{
  "easycom": {
    "^tn-(.*)": "@/tuniao-ui/components/tn-$1/tn-$1.vue"
  },
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
		  "path": "pages/index",
		  "style": {
		    "mp-weixin": {
		      "disableScroll": true
		    },
		    "app-plus": {
		      "bounce": "none"
		    },
		    "mp-alipay": {
		      "allowsBounceVertical": "NO"
		    },
		    "mp-baidu": {
		      "disableScroll": true
		    }
		  }
		}
	],
